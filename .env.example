# ── Execution mode ────────────────────────────────────────────────────────────
# "local"  — API runs directly on the MGS/MDS node (lfs + lctl run as subprocesses)
# "ssh"    — API runs on a client node; lfs + lctl are executed on the MGS via SSH
LUSTRE_API_LQA_MODE=ssh

# ── MGS HA hosts (comma-separated, or JSON array) ─────────────────────────────
# List all potential MGS nodes in priority order.
# The adapter probes them in order and caches the active one for mgs_cache_ttl seconds.
LUSTRE_API_MGS_HOSTS=192.168.1.10,192.168.1.11

# ── SSH credentials ───────────────────────────────────────────────────────────
# Only key-based authentication is supported.
LUSTRE_API_SSH_USER=root
LUSTRE_API_SSH_KEY=/root/.ssh/id_ed25519
LUSTRE_API_SSH_PORT=22

# ── Filesystem mountpoints ────────────────────────────────────────────────────
# JSON dict mapping fsname → mountpoint path on the MGS node.
# Required when LUSTRE_API_LQA_MODE=ssh (cannot read /proc/mounts remotely).
# Add one entry per Lustre filesystem this API manages.
LUSTRE_API_MOUNTPOINTS='{"aifs": "/lustre/aifs"}'

# ── Optional tuning ───────────────────────────────────────────────────────────
# LUSTRE_API_MGS_CACHE_TTL=60          # seconds to cache active MGS host
# LUSTRE_API_LFS_TIMEOUT=30            # seconds per lfs command
# LUSTRE_API_LCTL_TIMEOUT=30           # seconds per lctl command
# LUSTRE_API_SSH_CONNECT_TIMEOUT=5     # seconds for SSH handshake
# LUSTRE_API_ASSIGNMENT_STORE_PATH=./data/assignments.json
# LUSTRE_API_LFS_PATH=/usr/bin/lfs
# LUSTRE_API_LCTL_PATH=/usr/sbin/lctl
